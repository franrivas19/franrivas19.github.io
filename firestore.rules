rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid));
    }

    function isAdmin(uid) {
      return isSignedIn() && userDoc(uid).data.rol == 'admin';
    }

    function isMatchAdmin(partidoId) {
      return isSignedIn() && (
        isAdmin(request.auth.uid) ||
        get(/databases/$(database)/documents/partidos/$(partidoId)).data.adminPartido == request.auth.uid
      );
    }

    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin(request.auth.uid));
      allow delete: if isAdmin(request.auth.uid);
    }

    match /partidos/{partidoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.adminPartido == request.auth.uid;
      allow update: if isMatchAdmin(partidoId);
      allow delete: if isAdmin(request.auth.uid);

      match /votos/{votoId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && votoId == request.auth.uid
          && !exists(/databases/$(database)/documents/partidos/$(partidoId)/votos/$(request.auth.uid));
        allow update, delete: if false;
      }

      match /eventos_live/{eventoId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isMatchAdmin(partidoId);
      }
    }
  }
}